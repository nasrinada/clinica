rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       COMMON HELPERS
    ========================== */
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /* =========================
       USERS
    ========================== */
    match /users/{userId} {
      allow create: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin()
      );

      allow read: if isAuthenticated();

      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && isAdmin();
    }

    /* =========================
       DOCTORS
    ========================== */
    match /doctors/{doctorId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isAdmin();

      allow update: if isAuthenticated() && (
        request.auth.uid == doctorId ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && isAdmin();
    }

    /* =========================
       APPOINTMENTS
    ========================== */
    match /appointments/{appointmentId} {
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.patientId;

      allow read, update: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId ||
        request.auth.uid == resource.data.doctorId ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && isAdmin();
    }

    /* =========================
       CONVERSATIONS + MESSAGES
    ========================== */
    match /conversations/{conversationId} {

      // Helper to check if the current user can access the conversation doc.
      // Messages access relies on the conversation doc existing and containing participants.
      function canAccessConversationData(conversationData) {
        return conversationData != null
          && request.auth.uid in conversationData.participants
          && (!('blockedBy' in conversationData) || conversationData.blockedBy != request.auth.uid);
      }

      function canAccessConversation() {
        return exists(/databases/$(database)/documents/conversations/$(conversationId))
          && canAccessConversationData(
            get(/databases/$(database)/documents/conversations/$(conversationId)).data
          );
      }

      /* ---- READ CONVERSATIONS ---- */
      // For list queries (whereArrayContains), we allow if user is in participants
      // The blockedBy check is handled in the application layer for queries
      // For single document reads (get), we also check blockedBy
      allow list: if isAuthenticated()
        && resource.data != null
        && request.auth.uid in resource.data.participants;
      
      allow get: if isAuthenticated()
        && resource.data != null
        && request.auth.uid in resource.data.participants
        && (resource.data.blockedBy == null || resource.data.blockedBy != request.auth.uid);

      /* ---- CREATE CONVERSATION ---- */
      allow create: if isAuthenticated()
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      /* ---- UPDATE CONVERSATION ---- */
      allow update: if isAuthenticated()
        && resource.data != null
        && request.auth.uid in resource.data.participants
        && (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastMessageTimestamp', 'blockedBy', 'participants', 'unreadBy'])
          ||
          isAdmin()
        )
        && (
          !('participants' in request.resource.data)
          || request.resource.data.participants == resource.data.participants
          || isAdmin()
        );

      /* ---- DELETE CONVERSATION ---- */
      allow delete: if isAuthenticated() && isAdmin();

      /* =========================
         MESSAGES (SUBCOLLECTION)
      ========================== */
      match /messages/{messageId} {

        /* ---- READ MESSAGES (QUERY + SINGLE) ---- */
        allow list, get: if isAuthenticated()
          && canAccessConversation();

        /* ---- SEND MESSAGE ---- */
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && canAccessConversation();

        /* ---- DELETE MESSAGE ---- */
        allow delete: if isAuthenticated() && (
          (resource.data != null &&
           resource.data.senderId == request.auth.uid) ||
          isAdmin()
        );

        /* ---- UPDATE MESSAGE ---- */
        allow update: if isAuthenticated() && (
          isAdmin() ||
          (
            canAccessConversation() &&
            resource.data != null &&
            resource.data.senderId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text'])
          )
        );
      }
    }
  }
}
