<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HealthConnect" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="Theme.HealthConnect.Splash" parent="Theme.SplashScreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_playstore</item>
        <item name="postSplashScreenTheme">@style/Theme.HealthConnect</item>
    </style>
</resources>